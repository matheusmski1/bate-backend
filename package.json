{
  "name": "bate-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "start": "NODE_ENV=production tsx src/server/db/run-migrations.ts && NODE_ENV=production tsx src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:redis": "TEST_REDIS_URL=redis://localhost:6379 vitest run",
    "test:e2e": "TEST_E2E=1 vitest run tests/e2e",
    "typeorm": "node --import tsx ./node_modules/typeorm/cli.js",
    "migration:generate": "node --import tsx ./node_modules/typeorm/cli.js migration:generate -d src/server/db/data-source.ts",
    "migration:run": "node --import tsx ./node_modules/typeorm/cli.js migration:run -d src/server/db/data-source.ts",
    "migration:revert": "node --import tsx ./node_modules/typeorm/cli.js migration:revert -d src/server/db/data-source.ts",
    "seed": "tsx src/server/db/seed.ts",
    "loadtest": "tsx scripts/loadtest/run.ts",
    "loadtest:idle": "tsx scripts/loadtest/idle-scenario.ts"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.1",
    "typeorm": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.18.13",
    "@types/pg": "^8.20.0",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.20.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
